# LeagueAPI Docker Compose Configuration
# Copy this file to .env and fill in the required values

# --- Container Ports ---
LEAGUEAPI_PORT=8080
POSTGRES_PORT=5432

# --- PostgreSQL Configuration (Required) ---
POSTGRES_HOST=postgres
POSTGRES_DB=leagueapi
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_postgres_password_here

# --- SportsData.io Configuration (Required if enabled) ---
SPORTSDATA_ENABLED=true
SPORTSDATA_API_KEY=your_sportsdata_api_key_here

# --- Yahoo Fantasy Configuration (Required if enabled) ---
# Get these from Yahoo Developer Console: https://developer.yahoo.com/apps/
YAHOO_CLIENT_ID=your_yahoo_client_id_here
YAHOO_CLIENT_SECRET=your_yahoo_client_secret_here
YAHOO_REDIRECT_URI=http://localhost:3000
YAHOO_SYNC_ENABLED=true

# --- AgenticLeague LLM/Image Providers (Required for AgenticLeague) ---
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
XAI_API_KEY=your_xai_api_key_here
XAI_BASE_URL=https://api.x.ai/v1/

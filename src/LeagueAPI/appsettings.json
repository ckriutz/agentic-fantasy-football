{
  "ConnectionStrings": {
    "LeagueAPI": ""
  },
  "SleeperSync": {
    "Mode": "Auto",
    "Enabled": true,
    "RunOnStartup": true,
    "DailySyncHourUtc": 6,
    "PlayersEndpoint": "https://api.sleeper.app/v1/players/nfl",
    "SnapshotDirectory": "Data/sleeper",
    "StateFilePath": "Data/sleeper/latest-sync.json"
  },
  "SportsDataSync": {
    "Enabled": true,
    "RunOnStartup": true,
    "DailySyncHourUtc": 7,
    "BaseUrl": "https://api.sportsdata.io/v3/nfl/stats/json",
    "FantasyPlayersEndpoint": "FantasyPlayers",
    "ApiKey": ""
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
